rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // --- Entity Validations ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'createdAt'])
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 50
        && data.email is string && data.email.size() <= 100
        && data.role in ['아빠', '엄마', '할머니', '할아버지', '아들', '딸', '기타']
        && data.createdAt == request.time;
    }

    function isValidAnnouncement(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'authorName', 'createdAt', 'isNotice'])
        && data.title is string && data.title.size() <= 100
        && data.content is string && data.content.size() <= 5000
        && data.authorId == request.auth.uid
        && data.authorName is string && data.authorName.size() <= 100
        && data.createdAt == request.time
        && data.isNotice is bool;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'senderPhoto', 'createdAt'])
        && data.text is string && data.text.size() <= 1000
        && data.senderId == request.auth.uid
        && data.senderName is string && data.senderName.size() <= 100
        && data.createdAt == request.time;
    }

    function isValidFile(data) {
      return data.keys().hasAll(['name', 'url', 'type', 'sharedBy', 'sharedByName', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.url is string && data.url.size() <= 2000
        && data.type == 'link'
        && data.sharedBy == request.auth.uid
        && data.sharedByName is string && data.sharedByName.size() <= 100
        && data.createdAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isEmailVerified() && isValidUser(incoming());
      allow update: if isOwner(userId) && isEmailVerified() 
        && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName', 'photoURL'])
        && (incoming().role in ['아빠', '엄마', '할머니', '할아버지', '아들', '딸', '기타']);
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() && isValidAnnouncement(incoming());
      allow update: if isSignedIn() && isEmailVerified() && existing().authorId == request.auth.uid 
        && incoming().authorId == existing().authorId
        && isValidAnnouncement(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'isNotice']);
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() && isValidMessage(incoming());
      allow delete: if isSignedIn() && existing().senderId == request.auth.uid;
    }

    match /files/{fileId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() && isValidFile(incoming());
      allow delete: if isSignedIn() && existing().sharedBy == request.auth.uid;
    }
  }
}
